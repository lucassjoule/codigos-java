package io.github.lucassjoule.javaway;

import java.io.BufferedReader;
import java.io.InputStreamReader;
import java.net.ServerSocket;
import java.net.Socket;

/**
 * Hello world!
 *
 */
public class App 
{
    public static void main( String[] args )
    {
    	System.out.println("ouvindo...");
        try (ServerSocket server = new ServerSocket(3001)) {
			while (true) {
				Socket client = server.accept();
				
				System.out.println("escutando o cliente:" + client.getInetAddress().getHostName());
				receberEntradaDeTexto(server, client);
			}
        } catch (Exception e) {
			System.out.println("erro!! " + e);
		}
    }
    private static void receberEntradaDeTexto(ServerSocket server,Socket client) {
    	try {
    		InputStreamReader reader = new InputStreamReader(client.getInputStream());
    		BufferedReader input = new BufferedReader(reader);
    		String message = input.readLine();
    		System.out.println("mensagem obtida:" + message + ":O");
    	
		} catch (Exception e) {
			System.err.println("Erro ao ler a message!" + e);
		}

    	
    }
}
